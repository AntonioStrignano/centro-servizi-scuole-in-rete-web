---
import { navLinks, cta } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-black/10 bg-white/90 backdrop-blur">
  <div class="site-container grid h-20 grid-cols-[1fr_auto] items-center gap-4 md:grid-cols-[1fr_auto_1fr]">
    <a href="/" class="inline-flex items-center" aria-label="Centro Servizi Scuole In Rete - Home">
      <img src="/images/logo.png" alt="Logo Centro Servizi Scuole In Rete" class="h-9 w-auto" loading="eager" decoding="async" />
    </a>
    <nav class="hidden justify-self-center gap-8 md:flex" aria-label="Navigazione principale">
      {navLinks.map((item) => (
        <a
          href={item.href}
          class:list={[
            "border-b-2 pb-1 text-sm font-semibold tracking-wide transition-colors",
            currentPath === item.href
              ? "border-[var(--brand)] text-[var(--brand)]"
              : "border-transparent text-black/70 hover:text-[var(--brand)]",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex w-full items-center justify-end justify-self-end gap-2">
      <a href={cta.secondaryHref} class="hidden rounded-lg border border-black/20 px-4 py-2 text-xs font-semibold text-black/80 md:inline-flex">{cta.secondaryLabel}</a>
      <a href={cta.primaryHref} class="rounded-lg bg-[var(--brand)] px-4 py-2 text-xs font-semibold text-white shadow-sm">{cta.primaryLabel}</a>
      <details class="relative md:hidden">
        <summary class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-lg border border-black/15 text-black/75 transition hover:border-[var(--brand)] hover:text-[var(--brand)]">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
          <span class="sr-only">Apri menu di navigazione</span>
        </summary>
        <nav class="absolute right-0 top-12 w-56 rounded-xl border border-black/10 bg-white p-2 shadow-xl" aria-label="Navigazione mobile">
          {navLinks.map((item) => (
            <a
              href={item.href}
              class:list={[
                "block rounded-lg px-3 py-2 text-sm font-semibold transition-colors",
                currentPath === item.href
                  ? "bg-[var(--brand)]/10 text-[var(--brand)]"
                  : "text-black/75 hover:bg-black/5 hover:text-[var(--brand)]",
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
