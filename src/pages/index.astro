---
import MainLayout from "../layouts/MainLayout.astro";
import { cta } from "../data/site";

const serviceCards = [
  {
    title: "Formazione",
    href: "/servizi/formazione",
    description: "Aggiornamento costante per docenti e personale amministrativo su normative e innovazione didattica.",
  },
  {
    title: "Consulenza",
    href: "/servizi/consulenza",
    description: "Supporto legale, contabile e gestionale per accompagnare la crescita dell'istituto.",
  },
  {
    title: "Progettazione",
    href: "/servizi/progettazione",
    description: "Sviluppo progetti educativi, bandi e fondi per ampliare l'offerta formativa.",
  },
  {
    title: "Comunicazione",
    href: "/servizi/comunicazione",
    description: "Strategie di marketing scolastico e presenza digitale coordinate.",
  },
];
---

<MainLayout
  title="Centro Servizi Scuole In Rete | Home"
  description="Consulenza amministrativa, contabile e gestionale per scuole paritarie ed enti educativi privati. Scopri i servizi del Centro Servizi Scuole In Rete."
>
  <section class="section-pad">
    <div class="site-container split-grid items-center">
      <div>
        <p class="kicker">Consulenza per scuole ed enti privati</p>
        <h1 class="mt-4 text-4xl leading-tight text-[var(--brand)] md:text-6xl">Supporto amministrativo, contabile e gestionale per il mondo educativo privato</h1>
        <p class="mt-6 max-w-xl text-lg text-black/75">Affianchiamo scuole paritarie ed enti privati con un approccio operativo, rigoroso e orientato ai risultati. Trasformiamo la complessità burocratica in opportunità di crescita.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={cta.primaryHref} class="btn-primary">{cta.primaryLabel}</a>
          <a href={cta.secondaryHref} class="btn-secondary">{cta.secondaryLabel}</a>
        </div>
      </div>
      <div class="card-soft relative min-h-[380px] overflow-hidden p-6">
        <img
          src="/images/corridoio.jpg"
          alt="Corridoio scolastico luminoso"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/35 to-black/20"></div>
        <div class="absolute bottom-8 left-8 right-8 rounded-xl border border-white/20 bg-black/55 p-5 text-white shadow-lg backdrop-blur-[1px]">
          <p class="font-semibold">Qualità certificata</p>
          <p class="mt-1 text-sm text-white/90">Standard operativi d'eccellenza per la gestione scolastica e supporto continuativo alle direzioni.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--brand-soft)] py-10 text-white">
    <ul class="site-container grid gap-8 md:grid-cols-3">
      <li class="text-center md:text-left">
        <p class="text-5xl">30+</p>
        <p class="mt-1 text-sm uppercase tracking-[0.16em]">Anni di esperienza</p>
      </li>
      <li class="border-y border-white/20 py-6 text-center md:border-x md:border-y-0 md:px-8 md:py-0 md:text-left">
        <p class="text-5xl">300+</p>
        <p class="mt-1 text-sm uppercase tracking-[0.16em]">Scuole seguite</p>
      </li>
      <li class="text-center md:text-left">
        <p class="text-4xl">Esclusivi</p>
        <p class="mt-1 text-sm uppercase tracking-[0.16em]">Convegni per clienti</p>
      </li>
    </ul>
  </section>

  <section class="section-pad">
    <div class="site-container">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-4xl text-[var(--brand)]">I nostri servizi specializzati</h2>
        <p class="mt-4 text-black/70">Soluzioni integrate per ogni esigenza amministrativa e pedagogica del settore privato.</p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {serviceCards.map((card) => (
          <a href={card.href} class="card-soft p-6 transition hover:-translate-y-0.5 hover:shadow-xl">
            <h3 class="text-2xl text-[var(--brand)]">{card.title}</h3>
            <p class="mt-3 text-sm text-black/70">{card.description}</p>
            <p class="mt-6 text-sm font-semibold text-[var(--brand-2)]">Scopri di più</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white section-pad">
    <div class="site-container split-grid items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--brand-2)]">Metodologia</p>
        <h2 class="mt-4 text-5xl leading-tight text-[var(--brand)]">Un percorso rigoroso verso l'eccellenza gestionale</h2>
        <p class="mt-6 max-w-md text-black/70">Non offriamo semplici consigli, ma un affiancamento operativo che segue ogni fase della vita istituzionale.</p>
      </div>
      <div class="grid gap-7 sm:grid-cols-2">
        <article>
          <p class="text-5xl text-[var(--brand)]/20">01</p>
          <h3 class="mt-2 text-2xl text-[var(--brand)]">Analisi</h3>
          <p class="mt-2 text-sm text-black/70">Studio approfondito dello stato dell'arte dell'istituto e delle priorità operative.</p>
        </article>
        <article>
          <p class="text-5xl text-[var(--brand)]/20">02</p>
          <h3 class="mt-2 text-2xl text-[var(--brand)]">Strategia</h3>
          <p class="mt-2 text-sm text-black/70">Piano d'azione personalizzato e allineato agli obiettivi pedagogici ed economici.</p>
        </article>
        <article>
          <p class="text-5xl text-[var(--brand)]/20">03</p>
          <h3 class="mt-2 text-2xl text-[var(--brand)]">Esecuzione</h3>
          <p class="mt-2 text-sm text-black/70">Implementazione operativa con supporto diretto nella gestione delle pratiche quotidiane.</p>
        </article>
        <article>
          <p class="text-5xl text-[var(--brand)]/20">04</p>
          <h3 class="mt-2 text-2xl text-[var(--brand)]">Monitoraggio</h3>
          <p class="mt-2 text-sm text-black/70">Verifica continua dei risultati e adattamento alle evoluzioni normative.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-container rounded-3xl bg-[linear-gradient(135deg,#243f7a,#5f79b6)] p-10 text-center text-white md:p-20">
      <h2 class="mx-auto max-w-3xl text-5xl">Pronti a supportare la tua scuola?</h2>
      <p class="mx-auto mt-6 max-w-2xl text-white/85">Inizia oggi una collaborazione che valorizzerà il futuro educativo della tua istituzione.</p>
      <div class="mt-10">
        <a href={cta.primaryHref} class="inline-flex rounded-lg bg-white px-6 py-3 text-sm font-bold text-[var(--brand)]">Contattaci ora</a>
      </div>
    </div>
  </section>
</MainLayout>
