---
import MainLayout from "../layouts/MainLayout.astro";

const services = [
  { title: "Formazione", href: "/servizi/formazione", description: "Percorsi in presenza e online per staff scolastico." },
  { title: "Consulenza", href: "/servizi/consulenza", description: "Affiancamento amministrativo, gestionale e didattico." },
  { title: "Progettazione", href: "/servizi/progettazione", description: "Progettazione e attuazione di interventi e bandi." },
  { title: "Comunicazione", href: "/servizi/comunicazione", description: "Comunicazione interna/esterna chiara e coordinata." },
];
---

<MainLayout
  title="Servizi | Centro Servizi Scuole In Rete"
  description="Formazione, consulenza, progettazione e comunicazione per scuole paritarie. Servizi integrati per la gestione e la crescita degli istituti educativi."
>
  <section class="section-pad text-center">
    <div class="site-container">
      <p class="kicker">Eccellenza amministrativa</p>
      <h1 class="mx-auto mt-5 max-w-4xl text-5xl text-[var(--brand)] md:text-6xl">I nostri servizi per le scuole paritarie</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-black/70">Soluzioni integrate per la gestione amministrativa, didattica e comunicativa della tua istituzione.</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="site-container grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <a href={service.href} class="card-soft p-7 transition hover:-translate-y-0.5 hover:shadow-xl">
          <h2 class="text-3xl text-[var(--brand)]">{service.title}</h2>
          <p class="mt-4 text-sm text-black/70">{service.description}</p>
          <p class="mt-8 text-sm font-semibold text-[var(--brand-2)]">Scopri di più</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="site-container">
      <h2 class="text-5xl text-[var(--brand)]">Per chi lavoriamo</h2>
      <p class="mt-3 text-black/70">L'istituzione al centro del nostro ecosistema di supporto professionale.</p>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <article class="card-soft overflow-hidden">
          <img
            src="/images/ingresso%20scuola.jpg"
            alt="Studenti all'ingresso della scuola"
            class="h-44 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="p-7">
            <h3 class="text-3xl text-[var(--brand)]">Scuole paritarie</h3>
            <p class="mt-3 text-sm italic text-black/70">Sosteniamo l'eccellenza didattica attraverso una gestione amministrativa impeccabile.</p>
          </div>
        </article>
        <article class="card-soft overflow-hidden">
          <img
            src="/images/interno%20professionale.jpg"
            alt="Ambiente professionale interno"
            class="h-44 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="p-7">
            <h3 class="text-3xl text-[var(--brand)]">Enti educativi privati</h3>
            <p class="mt-3 text-sm italic text-black/70">Soluzioni strategiche per enti che vogliono crescere mantenendo solidità fiscale e gestionale.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="site-container rounded-3xl bg-[var(--brand)] p-10 text-center text-white md:p-16">
      <h2 class="text-5xl">Hai bisogno di una consulenza su misura?</h2>
      <p class="mx-auto mt-5 max-w-2xl text-white/80">Contattaci oggi stesso per un primo incontro conoscitivo.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/contatti" class="rounded-lg bg-white px-6 py-3 text-sm font-bold text-[var(--brand)]">Scrivici ora</a>
        <a href="/contatti" class="rounded-lg border border-white/60 px-6 py-3 text-sm font-bold">Prenota call</a>
      </div>
    </div>
  </section>
</MainLayout>
